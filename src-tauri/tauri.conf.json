{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mogy",
  "version": "2026.20.3",
  "identifier": "com.tcm.mogy",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mogy",
        "width": 1800,
        "height": 1150,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/minhtranin/mogy/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1NzhENjdBMDU4RjdGMUIKUldRYmY0OEZldFo0NWRHSlpleER0Z3EwL3d2cFFFQWp1MXpHbEg5WVh2RDBXVDdZQ0FqMnUyRCsK"
    }
  }
}
